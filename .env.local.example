# Skopiuj do .env.local i uzupełnij wartościami z projektu Supabase
# (Supabase → Project Settings → API).
#
# .env.local NIE trafia do gita (jest w .gitignore). Te same dwie zmienne
# ustawisz też w Vercel → Project → Settings → Environment Variables.

SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (klucz "service_role", trzymany tylko po stronie serwera)
